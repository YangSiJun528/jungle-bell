# Jungle Bell Windows installer bootstrap.
# Release workflow replaces __VERSION__ with the actual version before upload.
[CmdletBinding()]
param(
  [string]$Tag,
  [string]$Version
)

$ErrorActionPreference = 'Stop'
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$DefaultVersion = "__VERSION__"
$Repo = "YangSiJun528/jungle-bell"

if ($Version) {
  $resolvedTag = "v$Version"
} elseif ($Tag) {
  $resolvedTag = $Tag
} else {
  $resolvedTag = "v$DefaultVersion"
}
$ver = $resolvedTag.TrimStart('v')

$asset = "Jungle.Bell_${ver}_x64-setup.exe"
if ($env:JUNGLE_BELL_ASSET_URL) {
  $url = $env:JUNGLE_BELL_ASSET_URL
} else {
  $url = "https://github.com/$Repo/releases/download/$resolvedTag/$asset"
}

$tmp = Join-Path $env:TEMP ("jungle-bell-" + [guid]::NewGuid().ToString() + ".exe")

function Normalize-PathValue {
  param([string]$Value)

  if ([string]::IsNullOrWhiteSpace($Value)) {
    return $null
  }

  $path = [Environment]::ExpandEnvironmentVariables($Value.Trim())
  if ($path.StartsWith('"')) {
    $match = [regex]::Match($path, '^"([^"]+)"')
    if ($match.Success) {
      $path = $match.Groups[1].Value
    } else {
      $path = $path.Trim('"')
    }
  }

  $path = ($path -replace ',\d+$', '').Trim().Trim('"')
  if ([string]::IsNullOrWhiteSpace($path)) {
    return $null
  }
  return $path
}

function Join-ChildPath {
  param(
    [string]$Parent,
    [string]$Child
  )

  $parentPath = Normalize-PathValue $Parent
  if (-not $parentPath) {
    return $null
  }

  try {
    return Join-Path -Path $parentPath -ChildPath $Child -ErrorAction Stop
  } catch {
    return $null
  }
}

function Try-StartJungleBellPath {
  param([string]$Path)

  $candidate = Normalize-PathValue $Path
  if ($candidate -and (Test-Path -LiteralPath $candidate -PathType Leaf)) {
    Start-Process -FilePath $candidate
    return $true
  }
  return $false
}

function Start-JungleBell {
  $candidates = @()
  if ($env:LOCALAPPDATA) {
    $candidate = Join-ChildPath $env:LOCALAPPDATA 'Programs\Jungle Bell\Jungle Bell.exe'
    if ($candidate) { $candidates += $candidate }
  }
  $programW6432 = [Environment]::GetEnvironmentVariable('ProgramW6432')
  if ($programW6432) {
    $candidate = Join-ChildPath $programW6432 'Jungle Bell\Jungle Bell.exe'
    if ($candidate) { $candidates += $candidate }
  }
  if ($env:ProgramFiles) {
    $candidate = Join-ChildPath $env:ProgramFiles 'Jungle Bell\Jungle Bell.exe'
    if ($candidate) { $candidates += $candidate }
  }
  $programFilesX86 = [Environment]::GetEnvironmentVariable('ProgramFiles(x86)')
  if ($programFilesX86) {
    $candidate = Join-ChildPath $programFilesX86 'Jungle Bell\Jungle Bell.exe'
    if ($candidate) { $candidates += $candidate }
  }

  foreach ($candidate in ($candidates | Select-Object -Unique)) {
    if (Try-StartJungleBellPath $candidate) {
      return $true
    }
  }

  $uninstallRoots = @(
    'HKCU:\Software\Microsoft\Windows\CurrentVersion\Uninstall',
    'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall',
    'HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'
  )
  foreach ($root in $uninstallRoots) {
    if (-not (Test-Path -LiteralPath $root)) {
      continue
    }

    $app = Get-ChildItem -LiteralPath $root -ErrorAction SilentlyContinue |
      Get-ItemProperty -ErrorAction SilentlyContinue |
      Where-Object { $_.DisplayName -eq 'Jungle Bell' } |
      Select-Object -First 1
    if ($app -and $app.InstallLocation) {
      $candidate = Join-ChildPath $app.InstallLocation 'Jungle Bell.exe'
      if ($candidate -and (Try-StartJungleBellPath $candidate)) {
        return $true
      }
    }
    if ($app -and $app.DisplayIcon) {
      if (Try-StartJungleBellPath $app.DisplayIcon) {
        return $true
      }
    }
    if ($app -and $app.UninstallString) {
      $uninstaller = Normalize-PathValue $app.UninstallString
      if ($uninstaller) {
        $installDir = Split-Path -Parent $uninstaller -ErrorAction SilentlyContinue
        $candidate = Join-ChildPath $installDir 'Jungle Bell.exe'
        if ($candidate -and (Try-StartJungleBellPath $candidate)) {
          return $true
        }
      }
    }
  }

  $shortcutCandidates = @()
  if ($env:APPDATA) {
    $shortcut = Join-ChildPath $env:APPDATA 'Microsoft\Windows\Start Menu\Programs\Jungle Bell.lnk'
    if ($shortcut) { $shortcutCandidates += $shortcut }
  }
  if ($env:ProgramData) {
    $shortcut = Join-ChildPath $env:ProgramData 'Microsoft\Windows\Start Menu\Programs\Jungle Bell.lnk'
    if ($shortcut) { $shortcutCandidates += $shortcut }
  }

  foreach ($shortcut in ($shortcutCandidates | Select-Object -Unique)) {
    if (Test-Path -LiteralPath $shortcut -PathType Leaf) {
      Start-Process -FilePath $shortcut
      return $true
    }
  }

  $startMenuRoots = @()
  if ($env:APPDATA) {
    $root = Join-ChildPath $env:APPDATA 'Microsoft\Windows\Start Menu\Programs'
    if ($root) { $startMenuRoots += $root }
  }
  if ($env:ProgramData) {
    $root = Join-ChildPath $env:ProgramData 'Microsoft\Windows\Start Menu\Programs'
    if ($root) { $startMenuRoots += $root }
  }
  foreach ($root in ($startMenuRoots | Select-Object -Unique)) {
    if (-not (Test-Path -LiteralPath $root)) {
      continue
    }

    $shortcut = Get-ChildItem -LiteralPath $root -Filter 'Jungle Bell.lnk' -Recurse -ErrorAction SilentlyContinue |
      Select-Object -First 1
    if ($shortcut) {
      Start-Process -FilePath $shortcut.FullName
      return $true
    }
  }

  return $false
}

try {
  Write-Host "Downloading Jungle Bell $resolvedTag..."
  Invoke-WebRequest -UseBasicParsing -Uri $url -OutFile $tmp

  Write-Host "Installing silently..."
  $proc = Start-Process -FilePath $tmp -ArgumentList '/S' -Wait -PassThru
  if ($proc.ExitCode -ne 0) {
    throw "Installer exited with code $($proc.ExitCode)."
  }

  Write-Host "Opening Jungle Bell..."
  if (Start-JungleBell) {
    Write-Host "Installed and opened Jungle Bell."
  } else {
    Write-Warning "Installed, but couldn't find Jungle Bell to open. Launch it from the Start menu."
  }
}
finally {
  if (Test-Path $tmp) {
    Remove-Item $tmp -Force -ErrorAction SilentlyContinue
  }
}
